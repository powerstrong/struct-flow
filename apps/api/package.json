{
  "name": "@struct-flow/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev ./public --d1 DB=structmate-dev-db",
    "deploy": "wrangler pages deploy ./public",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate:dev": "wrangler d1 migrations apply structmate-dev-db --local",
    "migrate:prod": "wrangler d1 migrations apply structmate-prod-db --remote"
  },
  "dependencies": {
    "@struct-flow/shared": "*",
    "drizzle-orm": "0.36.4",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20241127.0",
    "drizzle-kit": "0.28.1",
    "typescript": "5.6.3",
    "vitest": "2.1.5",
    "wrangler": "3.91.0"
  }
}
